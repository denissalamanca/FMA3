//+------------------------------------------------------------------+
//| CheckCoreSignal.mq5 — compile/smoke gate for                     |
//| Core/CoreSignal.mqh (UNIT 3 of the S2 live-Core build).          |
//|                                                                  |
//| NO trading functions, NO files.  Four blocks:                    |
//|   1. structural smoke: opex calendar (v5_sleeves 3rd-Friday      |
//|      weeks, 375 days), policy step tables, CsDaysFromCivil;      |
//|   2. PYTHON-GOLDEN block: a deterministic synthetic 240-day /    |
//|      1440-bar run (64-bit LCG price walk, IEEE-exact in both     |
//|      languages) through CCoreSignal, compared at 50 sampled bars |
//|      per leg against values generated from the NORMATIVE         |
//|      reference (core_signal_reference.gen_*, fma kernels) by     |
//|      gen_coresignal_check_golden.py.  Criterion = the owner-     |
//|      ratified max|d| <= 1e-12 AND 0 sign flips (the mirror       |
//|      measured the fma emulation bit-equal, so bit-zero is        |
//|      expected — the bit count is reported);                      |
//|   3. state round-trip: GetState -> fresh SetState mid-run, blob  |
//|      string equality, then both objects stepped to the end with  |
//|      every target bit-compared (+ defer-hold invariants);        |
//|   4. CCoreTrigger smoke: band fire with min-gap suppression      |
//|      (breach on a skipped day does NOT latch), harvest fire      |
//|      without gap, hold-at-legcap held-row telemetry, state       |
//|      round-trip, non-ascending-day guard.                        |
//|                                                                  |
//| The terminal Print output must end with                          |
//| "CheckCoreSignal: ALL PASS".                                     |
//+------------------------------------------------------------------+
#property copyright "FMA3"
#property version   "1.00"

#include <Core/CoreSignal.mqh>

int g_fail = 0;

void Expect(const bool ok, const string what)
  {
   if(!ok)
     {
      g_fail++;
      Print("CheckCoreSignal FAIL: ", what);
     }
  }

//==================================================================//
