double g_mine[9][CSG_NBARS];     // primary-object targets, every bar

double CsgSign(const double x)
  {
   if(x > 0.0) return 1.0;
   if(x < 0.0) return -1.0;
   return 0.0;
  }

//+------------------------------------------------------------------+
void SmokeTables(void)
  {
   //--- CsDaysFromCivil
   Expect(CsDaysFromCivil(1970, 1, 1) == 0,      "days_from_civil 1970-01-01");
   Expect(CsDaysFromCivil(2024, 1, 1) == 19723,  "days_from_civil 2024-01-01");
   Expect(CsDaysFromCivil(2019, 12, 1) == 18231, "days_from_civil 2019-12-01");
   Expect(CsDaysFromCivil(2026, 2, 1) == 20485,  "days_from_civil 2026-02-01");

   //--- opex calendar (375 days, 2019-12 .. 2026-02)
   CCsOpexCal cal;
   cal.Init();
   Expect(cal.Count() == 375,   "opex count 375");
   Expect(cal.First() == 18246, "opex first 2019-12-16");
   Expect(cal.Last() == 20504,  "opex last 2026-02-20");
   Expect(cal.In(19947),  "opex 2024-08-12 in");     // Mon of Aug-2024 week
   Expect(cal.In(19951),  "opex 2024-08-16 in");     // 3rd Friday
   Expect(!cal.In(19954), "opex 2024-08-19 out");
   Expect(cal.In(18337),  "opex 2020-03-16 in");
   Expect(cal.In(20500),  "opex 2026-02-16 in");
   Expect(!cal.In(18245), "opex 2019-12-15 out");

   //--- policy step tables
   CCsPolicy pol;
   pol.Init();
   Expect(pol.RateUsd(18200) == 1.625, "usd before-first -> rates[0]");
   Expect(pol.RateUsd(18201) == 1.625, "usd 2019-11-01");
   Expect(pol.RateUsd(18336) == 0.125, "usd 2020-03-15");
   Expect(pol.RateUsd(18400) == 0.125, "usd mid-2020");
   Expect(pol.RateUsd(19999) == 4.875, "usd 2024-10");
   Expect(pol.RateUsd(20433) == 3.625, "usd 2025-12-11");
   Expect(pol.RateJpy(19800) == -0.10, "jpy pre-hike");
   Expect(pol.RateJpy(19801) == 0.10,  "jpy 2024-03-19");
   Expect(pol.RateJpy(19935) == 0.25,  "jpy 2024-07-31");
   Expect(pol.RateJpy(20112) == 0.50,  "jpy 2025-01-24");
  }

//+------------------------------------------------------------------+
void SyntheticGoldenRun(void)
  {
   ulong  s[CS_NINST];
   double m[CS_NINST];
   for(int i = 0; i < CS_NINST; i++)
     {
      s[i] = (ulong)0x9E3779B97F4A7C15 * (ulong)(i + 1);
      m[i] = CSG_BASE[i];
     }

   CCoreSignal sig;
   sig.Configure();
   CCoreSignal sig2;                 // restored twin (from CSG_SPLIT on)
   sig2.Configure();
   bool restored = false;
   long tail_diffs = 0;

   int k = 0;
   for(int day = 0; day < CSG_NDAYS; day++)
     {
      for(int hh = 0; hh < CSG_NBPD; hh++)
        {
         long ts = ((long)(CSG_E0 + day)) * 86400
                   + (long)CSG_HOURS[hh] * 3600 + 1800;
         for(int i = 0; i < CS_NINST; i++)
           {
            s[i] = s[i] * 6364136223846793005 + 1442695040888963407;
            double u = (double)((s[i] >> 40) & 0xFFFFFF) / 16777216.0;
            m[i] = m[i] * (1.0 + ((u - 0.5) * 0.02 + 0.0004));
            double spr = m[i] * 0.0003;
            double bid = m[i] - spr * 0.5;
            double ask = m[i] + spr * 0.5;
            Expect(sig.StepBar(i, ts, bid, ask),
                   "StepBar " + sig.LastError());
            if(restored)
               Expect(sig2.StepBar(i, ts, bid, ask),
                      "twin StepBar " + sig2.LastError());
           }
         for(int leg = 0; leg < CS_NLEGS; leg++)
           {
            g_mine[leg][k] = sig.Tgt(leg);
            if(restored && sig2.Tgt(leg) != sig.Tgt(leg))
               tail_diffs++;
           }
         //--- state round-trip at the split bar --------------------
         if(k == CSG_SPLIT)
           {
            string s1 = sig.GetState();
            Expect(sig2.SetState(s1), "SetState: " + sig2.LastError());
            string s2 = sig2.GetState();
            Expect(s1 == s2, "state round-trip blob equality");
            PrintFormat("CheckCoreSignal state: blob %d chars, round-trip %s",
                        StringLen(s1), (s1 == s2) ? "EXACT" : "DIFFERS");
            restored = true;
           }
         k++;
        }
     }
   Expect(k == CSG_NBARS, "bar count");
   Expect(tail_diffs == 0, StringFormat("restored-twin tail: %I64d target "
                                        "diffs (must be 0)", tail_diffs));
   PrintFormat("CheckCoreSignal split: restored twin re-stepped bars %d..%d, "
               "target diffs = %I64d", CSG_SPLIT + 1, CSG_NBARS - 1, tail_diffs);

   //--- python-golden comparison at the sampled bars ----------------
   bool all_ok = true;
   for(int leg = 0; leg < CS_NLEGS; leg++)
     {
      int    nbit = 0, flips = 0, ngt = 0;
      double maxd = 0.0;
      for(int q = 0; q < CSG_NSAMP; q++)
        {
         double mine = g_mine[leg][CSG_SAMPLE_POS[q]];
         double gold = CSG_EXPECT[leg][q];
         if(mine == gold)
            nbit++;
         double dd = MathAbs(mine - gold);
         if(dd > maxd) maxd = dd;
         if(dd > 1e-12) ngt++;
         if(CsgSign(mine) != CsgSign(gold)) flips++;
        }
      bool ok = (maxd <= 1e-12 && flips == 0);
      all_ok = all_ok && ok;
      PrintFormat("CheckCoreSignal golden leg %d: bit %d/%d max|d|=%.3e "
                  ">1e-12: %d flips=%d %s",
                  leg, nbit, CSG_NSAMP, maxd, ngt, flips, ok ? "OK" : "FAIL");
      Expect(ok, StringFormat("golden leg %d (max|d|=%.3e flips=%d)",
                              leg, maxd, flips));
     }

   //--- defer-hold invariant on the last synthetic day --------------
   // bar layout per day: h in {1,10,19,21,22,23} -> the 21:30 and 22:30
   // outputs of the deferred legs 0..4 must equal the 19:30 output
   int base = (CSG_NDAYS - 1) * CSG_NBPD;
   for(int leg2 = 0; leg2 <= 4; leg2++)
     {
      Expect(g_mine[leg2][base + 3] == g_mine[leg2][base + 2],
             StringFormat("defer hold leg %d @21h", leg2));
      Expect(g_mine[leg2][base + 4] == g_mine[leg2][base + 2],
             StringFormat("defer hold leg %d @22h", leg2));
     }

   //--- ascending-stamp guard ----------------------------------------
   Expect(!sig.StepBar(0, 1000, 1.0, 1.0), "stale stamp must be refused");
  }

//+------------------------------------------------------------------+
void SmokeTrigger(void)
  {
   int legSlot[9] = {0, 1, 2, 3, 4, 5, 5, 5, 6};
   double up = 0.25;
   double down = (1.0 / 7.0) / 1.75;
   CCoreTrigger trig;
   Expect(trig.Configure(7, 9, legSlot, up, down, 2.5, 5),
          "trigger Configure: " + trig.LastError());

   long D0 = 20000;
   bool fired = false;

   //--- (a) band fire with min-gap suppression -----------------------
   // slot 0 breaches shares (2300/8300 = 0.277 > 0.25) from day D0+2 on
   // but stays below the harvest thr (2300 < 2.5*7000/7 = 2500); the
   // breach must NOT latch on days D0+2..D0+4 (gap < 5) and must fire
   // on the D0+5 row (gap = 5), act D0+6.
   Expect(trig.BeginSegment(7000.0, D0), "BeginSegment a");
   for(long dd = D0 + 1; dd <= D0 + 6; dd++)
     {
      long ts = dd * 86400 + 3600;
      Expect(trig.CheckDay(ts, fired), "CheckDay a: " + trig.LastError());
      if(dd < D0 + 6)
         Expect(!fired, StringFormat("premature fire day +%d", (int)(dd - D0)));
      else
        {
         Expect(fired, "band must fire on the +5 row");
         if(fired)
           {
            Expect(trig.Kind() == "band",        "kind band");
            Expect(trig.DecidedDay() == D0 + 5,  "decided day +5");
            Expect(trig.ActDay() == D0 + 6,      "act day +6");
            Expect(trig.MaxSlot() == 0,          "max slot 0");
            Expect(trig.MaxShare() > 0.25,       "max share > up");
           }
        }
      if(fired)
         break;
      for(int l = 0; l < 9; l++)
        {
         double eq;
         if(l == 0)
            eq = (dd >= D0 + 2) ? 2300.0 : 1000.0;
         else if(l >= 5 && l <= 7)
            eq = 1000.0 / 3.0;
         else
            eq = 1000.0;
         Expect(trig.OnLegBar(l, ts, eq), "OnLegBar a");
        }
     }

   //--- (b) harvest fires with NO min-gap -----------------------------
   Expect(trig.BeginSegment(7000.0, D0), "BeginSegment b");
   for(int l2 = 0; l2 < 9; l2++)
     {
      double eq = (l2 == 2) ? 2600.0
                  : ((l2 >= 5 && l2 <= 7) ? 1000.0 / 3.0 : 1000.0);
      Expect(trig.OnLegBar(l2, (D0 + 1) * 86400 + 3600, eq), "OnLegBar b");
     }
   Expect(trig.CheckDay((D0 + 2) * 86400 + 3600, fired), "CheckDay b");
   Expect(fired, "harvest must fire without gap");
   if(fired)
     {
      Expect(trig.Kind() == "harvest",       "kind harvest");
      Expect(trig.DecidedDay() == D0 + 1,    "decided day +1");
      Expect(trig.ActDay() == D0 + 2,        "act day +2");
     }

   //--- (c) hold-at-legcap held-row telemetry -------------------------
   long held0 = trig.HeldRows();
   long rows0 = trig.RowsScanned();
   Expect(trig.BeginSegment(7000.0, D0), "BeginSegment c");
   for(int l3 = 0; l3 < 9; l3++)
     {
      if(l3 >= 5 && l3 <= 7)
         continue;                        // the S6 slot never prints
      Expect(trig.OnLegBar(l3, (D0 + 1) * 86400 + 3600, 1000.0), "OnLegBar c");
     }
   Expect(trig.CheckDay((D0 + 2) * 86400 + 3600, fired), "CheckDay c");
   Expect(!fired, "legcap-held equal shares must not fire");
   Expect(trig.RowsScanned() == rows0 + 1, "rows_scanned +1");
   Expect(trig.HeldRows() == held0 + 1,    "held_rows +1 (S6 held)");

   //--- (d) state round-trip ------------------------------------------
   string t1 = trig.GetState();
   CCoreTrigger trig2;
   Expect(trig2.Configure(7, 9, legSlot, up, down, 2.5, 5), "Configure d");
   Expect(trig2.SetState(t1), "trigger SetState: " + trig2.LastError());
   Expect(trig2.GetState() == t1, "trigger state round-trip equality");

   //--- (e) non-ascending day guard -----------------------------------
   Expect(!trig.CheckDay((D0 - 5) * 86400, fired), "stale day must be refused");
  }

//+------------------------------------------------------------------+
void OnStart()
  {
   Print("CheckCoreSignal: structural smoke + synthetic python-golden run ...");
   SmokeTables();
   SyntheticGoldenRun();
   SmokeTrigger();
   if(g_fail == 0)
      Print("CheckCoreSignal: ALL PASS");
   else
      PrintFormat("CheckCoreSignal: %d FAILURES", g_fail);
  }
//+------------------------------------------------------------------+
